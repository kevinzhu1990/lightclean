{
  "name": "lightclean",
  "version": "1.2.4",
  "description": "轻净 LightClean — a cross-platform system cleaner and privacy tool with safe WeChat history cleanup",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:linux": "electron-vite build && electron-builder --linux",
    "package:all": "electron-vite build && electron-builder --win --mac --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:rules": "npx tsx src/main/rules/validate.ts",
    "new-rule": "node scripts/new-rule.js",
    "find-cache": "node scripts/find-cache.js",
    "preview-rule": "node scripts/preview-rule.js",
    "parity-check": "node scripts/parity-check.js",
    "catalog": "node scripts/generate-catalog.js",
    "translate": "node scripts/translate.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release": "node scripts/release.js",
    "postinstall": "patch-package && electron-rebuild -w better-sqlite3"
  },
  "keywords": [
    "system-cleaner",
    "electron",
    "windows",
    "macos",
    "linux",
    "optimization"
  ],
  "author": {
    "name": "LightClean Contributors"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinzhu1990/lightclean.git"
  },
  "homepage": "https://github.com/kevinzhu1990/lightclean",
  "bugs": {
    "url": "https://github.com/kevinzhu1990/lightclean/issues"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.2",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "ajv": "^8.18.0",
    "conventional-changelog-cli": "^5.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "patch-package": "^8.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@litko/yara-x": "^0.6.1",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.0",
    "lucide-react": "^0.577.0",
    "pusher-js": "^8.4.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "systeminformation": "^5.31.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  }
}
